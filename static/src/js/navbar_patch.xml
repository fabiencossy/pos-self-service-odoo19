<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Add a self-service menu button in navbar (always visible, toggles mode via PIN) -->
    <t t-name="pos_self_service.Navbar" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">
        <xpath expr="//CashierName" position="after">
            <button class="btn btn-light btn-lg lh-lg pos-self-service-menu-btn" t-on-click="onSelfServiceMenuClick"
                    title="Self-Service">
                <i class="fa fa-fw fa-lock"/>
            </button>
        </xpath>
    </t>

    <!-- Add "no change given" warning on payment screen -->
    <t t-name="pos_self_service.PaymentScreenMethods" t-inherit="point_of_sale.PaymentScreenMethods" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('paymentmethods-container')]" position="before">
            <div class="alert alert-warning text-center fw-bold mb-2 py-2 pos-self-service-no-change-msg">
                <i class="fa fa-exclamation-triangle me-2"/>
                Nous ne rendons pas la monnaie
            </div>
        </xpath>
    </t>

</templates>
