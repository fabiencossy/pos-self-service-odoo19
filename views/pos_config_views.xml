<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_config_view_form_self_service" model="ir.ui.view">
        <field name="name">pos.config.form.self.service</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Self-Service" name="self_service_group">
                    <group>
                        <field name="self_service_mode"/>
                        <field name="self_service_pin" invisible="not self_service_mode" password="True"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
